{
  "name": "gama-monitor",
  "version": "1.0.0",
  "description": "Gama Monitor — Real-time project hub with Design System control",
  "private": true,
  "scripts": {
    "dev": "node start.js",
    "build": "next build",
    "start": "next start -p 3015",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "tunnel": "cloudflared tunnel --url http://localhost:3015",
    "terminal": "ttyd -p 3020 -W -t fontSize=16 -t titleFixed=GAMA\\ Terminal powershell -NoLogo",
    "terminal:cmd": "ttyd -p 3020 -W -t fontSize=16 cmd.exe /K",
    "dev:full": "concurrently \"node start.js\" \"npm run terminal\"",
    "setup": "powershell -ExecutionPolicy Bypass -File scripts/setup.ps1",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "dependencies": {
    "lucide-react": "^0.401.0",
    "next": "^15.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^3.8.1",
    "tailwindcss": "^3.4.1"
  },
  "devDependencies": {
    "@types/node": "^20.10.6",
    "@types/react": "^18.2.45",
    "@types/react-dom": "^18.2.18",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "autoprefixer": "^10.4.16",
    "concurrently": "^9.2.1",
    "eslint": "^8.56.0",
    "eslint-config-next": "^15.0.0",
    "postcss": "^8.4.32",
    "typescript": "^5.3.3"
  }
}
